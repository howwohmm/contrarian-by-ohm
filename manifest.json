{
  "manifest_version": 3,
  "name": "Contrarian",
  "description": "Words worth sitting with. Paul Graham — and the minds he reads.",
  "version": "1.0.0",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["quotes.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
